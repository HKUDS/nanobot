# Nanobot Production — Environment Variables
#
# Copy to .env and fill in your values.
# See .env.example at the repo root for the full variable reference.

# ── Docker image ───────────────────────────────────────────────────────
NANOBOT_IMAGE=ghcr.io/cgajagon/nanobot:latest

# ── Config directory on host ───────────────────────────────────────────
NANOBOT_CONFIG_DIR=~/.nanobot

# ── Neo4j ──────────────────────────────────────────────────────────────
NEO4J_AUTH=neo4j/nanobot_graph

# ── LLM Provider Keys (uncomment and set) ─────────────────────────────
# NANOBOT_PROVIDERS__ANTHROPIC__API_KEY=sk-ant-...
# NANOBOT_PROVIDERS__OPENAI__API_KEY=sk-...
# NANOBOT_PROVIDERS__OPENROUTER__API_KEY=sk-or-...

# ── Channels (uncomment as needed) ────────────────────────────────────
# NANOBOT_CHANNELS__TELEGRAM__TOKEN=...
# NANOBOT_CHANNELS__TELEGRAM__ENABLED=true
# NANOBOT_CHANNELS__DISCORD__TOKEN=...
# NANOBOT_CHANNELS__DISCORD__ENABLED=true

# ── Observability ─────────────────────────────────────────────────────
# NANOBOT_LANGFUSE__ENABLED=true
# NANOBOT_LANGFUSE__PUBLIC_KEY=pk-lf-...
# NANOBOT_LANGFUSE__SECRET_KEY=sk-lf-...
# NANOBOT_LANGFUSE__HOST=https://cloud.langfuse.com
