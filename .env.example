# Nanobot — Environment Variable Reference
#
# Copy to `.env` and uncomment the variables you want to override.
# See nanobot/config/schema.py for the full Pydantic model definitions.
#
# Priority: env vars (highest) → .env file → ~/.nanobot/config.json → defaults
# Prefix:   NANOBOT_
# Nesting:  double-underscore  (e.g.  NANOBOT_AGENTS__DEFAULTS__MODEL)

# ── LLM Provider API Keys ─────────────────────────────────────────────
# NANOBOT_PROVIDERS__ANTHROPIC__API_KEY=sk-ant-...
# NANOBOT_PROVIDERS__OPENAI__API_KEY=sk-...
# NANOBOT_PROVIDERS__OPENROUTER__API_KEY=sk-or-...
# NANOBOT_PROVIDERS__DEEPSEEK__API_KEY=sk-...
# NANOBOT_PROVIDERS__GROQ__API_KEY=gsk_...
# NANOBOT_PROVIDERS__GEMINI__API_KEY=...
# NANOBOT_PROVIDERS__CUSTOM__API_KEY=...
# NANOBOT_PROVIDERS__CUSTOM__API_BASE=https://your-endpoint/v1

# ── Agent Defaults ─────────────────────────────────────────────────────
# NANOBOT_AGENTS__DEFAULTS__MODEL=anthropic/claude-opus-4-5
# NANOBOT_AGENTS__DEFAULTS__MAX_TOKENS=8192
# NANOBOT_AGENTS__DEFAULTS__TEMPERATURE=0.1
# NANOBOT_AGENTS__DEFAULTS__MAX_TOOL_ITERATIONS=40

# ── Feature Flags ──────────────────────────────────────────────────────
# NANOBOT_FEATURES__PLANNING_ENABLED=true
# NANOBOT_FEATURES__VERIFICATION_ENABLED=true
# NANOBOT_FEATURES__DELEGATION_ENABLED=true
# NANOBOT_FEATURES__MEMORY_ENABLED=true
# NANOBOT_FEATURES__SKILLS_ENABLED=true
# NANOBOT_FEATURES__STREAMING_ENABLED=true

# ── LLM Call Tuning ───────────────────────────────────────────────────
# NANOBOT_LLM__TIMEOUT_S=60.0
# NANOBOT_LLM__MAX_RETRIES=1

# ── Memory ─────────────────────────────────────────────────────────────
# NANOBOT_AGENTS__DEFAULTS__MEMORY_ROLLOUT_MODE=enabled   # enabled|shadow|disabled
# NANOBOT_AGENTS__DEFAULTS__MEMORY_RETRIEVAL_K=6
# NANOBOT_AGENTS__DEFAULTS__MEMORY_TOKEN_BUDGET=900
# NANOBOT_AGENTS__DEFAULTS__MEMORY_SHADOW_SAMPLE_RATE=0.2

# ── Knowledge Graph (Neo4j) ───────────────────────────────────────────
# NANOBOT_AGENTS__DEFAULTS__GRAPH_ENABLED=false
# NANOBOT_AGENTS__DEFAULTS__GRAPH_NEO4J_URI=bolt://localhost:7687
# NANOBOT_AGENTS__DEFAULTS__GRAPH_NEO4J_AUTH=neo4j/nanobot_graph
# NANOBOT_AGENTS__DEFAULTS__GRAPH_NEO4J_DATABASE=neo4j

# ── Gateway ────────────────────────────────────────────────────────────
# NANOBOT_GATEWAY__HOST=0.0.0.0
# NANOBOT_GATEWAY__PORT=18790
# NANOBOT_GATEWAY__HEARTBEAT__ENABLED=false
# NANOBOT_GATEWAY__HEARTBEAT__INTERVAL_S=1800

# ── Channels ───────────────────────────────────────────────────────────
# NANOBOT_CHANNELS__TELEGRAM__ENABLED=false
# NANOBOT_CHANNELS__TELEGRAM__TOKEN=
# NANOBOT_CHANNELS__DISCORD__ENABLED=false
# NANOBOT_CHANNELS__DISCORD__TOKEN=
# NANOBOT_CHANNELS__SLACK__ENABLED=false
# NANOBOT_CHANNELS__SLACK__BOT_TOKEN=xoxb-...
# NANOBOT_CHANNELS__SLACK__APP_TOKEN=xapp-...

# ── Tools ──────────────────────────────────────────────────────────────
# NANOBOT_TOOLS__RESTRICT_TO_WORKSPACE=false
# NANOBOT_TOOLS__EXEC__TIMEOUT=60
# NANOBOT_TOOLS__WEB__SEARCH__API_KEY=       # Brave Search API key

# ── Reranker ───────────────────────────────────────────────────────────
# NANOBOT_AGENTS__DEFAULTS__RERANKER__MODE=disabled    # enabled|shadow|disabled
# NANOBOT_AGENTS__DEFAULTS__RERANKER__ALPHA=0.5
# NANOBOT_AGENTS__DEFAULTS__RERANKER__MODEL=

# ── mem0 ───────────────────────────────────────────────────────────────
# NANOBOT_AGENTS__DEFAULTS__MEM0__USER_ID=nanobot
# NANOBOT_AGENTS__DEFAULTS__MEM0__ADD_DEBUG=false
# NANOBOT_AGENTS__DEFAULTS__MEM0__VERIFY_WRITE=true
# NANOBOT_AGENTS__DEFAULTS__MEM0__FORCE_INFER_TRUE=false
