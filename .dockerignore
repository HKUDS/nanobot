# Build context exclusions — keep Docker image builds fast

# Python artifacts
__pycache__/
*.pyc
*.pyo
*.pyd
*.egg-info/
dist/
build/
.mypy_cache/
.pytest_cache/
.ruff_cache/

# Git and CI
.git/
.github/

# Tests, docs, and tooling (not needed in the image)
tests/
docs/
artifacts/
case/
scripts/
memory/

# Frontend dev artifacts (built frontend copied separately if needed)
frontend/node_modules/
frontend/.vite/

# Deployment and infrastructure
deploy/
terraform/

# Misc
*.md
!README.md
.env
.env.*
.assets
.dockerignore
Makefile

# Bridge source included (tiny, ~10KB) — needed by hatchling force-include
# during pip install.  The bridge won't run without Node.js.

# Runtime data
workspace/
