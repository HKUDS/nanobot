# Normalize text files to LF across platforms.
* text=auto eol=lf

# Source, config, and documentation files.
*.css text eol=lf
*.html text eol=lf
*.js text eol=lf
*.json text eol=lf
*.jsx text eol=lf
*.md text eol=lf
*.mjs text eol=lf
*.py text eol=lf
*.sh text eol=lf
*.toml text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.txt text eol=lf
*.yml text eol=lf
*.yaml text eol=lf

# Binary assets.
*.gif binary
*.ico binary
*.jpeg binary
*.jpg binary
*.png binary
*.ttf binary
*.webp binary
*.woff binary
*.woff2 binary
