# nanobot Environment Configuration
# Copy to `.env` and fill in your values

# Slack Channel (Socket Mode)
NANOBOT_CHANNELS__SLACK__BOT_TOKEN=xoxb-...
NANOBOT_CHANNELS__SLACK__APP_TOKEN=xapp-...

# LLM Providers
NANOBOT_PROVIDERS__ANTHROPIC__API_KEY=sk-ant-...
NANOBOT_PROVIDERS__OPENROUTER__API_KEY=sk-or-v1-...

# Web Search (optional)
NANOBOT_TOOLS__WEB__SEARCH__API_KEY=...
