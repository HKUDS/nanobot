# Nanobot Staging — Environment Variables
#
# Copy to .env and fill in your values.
# Staging uses a separate config directory (~/.nanobot-staging) and port 18791.

# ── Docker image ───────────────────────────────────────────────────────
NANOBOT_IMAGE=ghcr.io/cgajagon/nanobot:latest

# ── Config directory on host (separate from production) ────────────────
NANOBOT_CONFIG_DIR=~/.nanobot-staging

# ── LLM Provider Keys (use same keys or cheaper models for staging) ────
# NANOBOT_PROVIDERS__ANTHROPIC__API_KEY=sk-ant-...
# NANOBOT_PROVIDERS__OPENAI__API_KEY=sk-...
# NANOBOT_AGENTS__DEFAULTS__MODEL=anthropic/claude-sonnet-4-20250514

# ── Disable graph features (no Neo4j in staging) ──────────────────────
# NANOBOT_FEATURES__GRAPH_ENABLED=false

# ── Channels (use test tokens or disable in staging) ──────────────────
# NANOBOT_CHANNELS__TELEGRAM__ENABLED=false
# NANOBOT_CHANNELS__DISCORD__ENABLED=false

# ── Observability ─────────────────────────────────────────────────────
# NANOBOT_LANGFUSE__ENABLED=true
# NANOBOT_LANGFUSE__ENVIRONMENT=staging
