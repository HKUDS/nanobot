# Nanobot Browser Automation - Environment Configuration
# Copy this file to .env and fill in your values

# ============================================================
# LLM Provider API Keys (at least one required)
# ============================================================

# OpenRouter (recommended, supports many models)
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Or use direct provider APIs:
OPENAI_API_KEY=your_openai_key_here
ANTHROPIC_API_KEY=your_anthropic_key_here

# ============================================================
# Model Configuration
# ============================================================

# Default model for agent
DEFAULT_MODEL=anthropic/claude-opus-4-5
# Other options:
# DEFAULT_MODEL=openrouter/openai/gpt-4o
# DEFAULT_MODEL=openrouter/anthropic/claude-3.5-sonnet

# ============================================================
# Browser Configuration
# ============================================================

# Enable VNC for remote desktop debugging (default: false)
VNC_ENABLED=false

# Set to false to enable headed mode (requires VNC_ENABLED=true)
# NANOBOT__TOOLS__BROWSER__HEADLESS=true

# Viewport size
# NANOBOT__TOOLS__BROWSER__VIEWPORT_WIDTH=1280
# NANOBOT__TOOLS__BROWSER__VIEWPORT_HEIGHT=720

# ============================================================
# Gateway Configuration
# ============================================================

# Port for nanobot gateway
NANOBOT_PORT=18790

# ============================================================
# Advanced Browser Settings (usually don't need to change)
# ============================================================

# Browser type: chromium, firefox, webkit
# NANOBOT__TOOLS__BROWSER__BROWSER_TYPE=chromium

# Slow down operations (ms) - useful for debugging
# NANOBOT__TOOLS__BROWSER__SLOW_MO=0

# Default timeout for browser operations (ms)
# NANOBOT__TOOLS__BROWSER__DEFAULT_TIMEOUT=30000

# Custom User-Agent
# NANOBOT__TOOLS__BROWSER__USER_AGENT=Mozilla/5.0 ...

# Ignore HTTPS errors (useful for self-signed certs)
# NANOBOT__TOOLS__BROWSER__IGNORE_HTTPS_ERRORS=false
