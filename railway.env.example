# Required (OpenRouter example)
NANOBOT_PROVIDERS__OPENROUTER__API_KEY=sk-or-v1-xxxx
NANOBOT_AGENTS__DEFAULTS__PROVIDER=openrouter
NANOBOT_AGENTS__DEFAULTS__MODEL=anthropic/claude-opus-4-5

# Required for public deployments: protect Web UI APIs
NANOBOT_WEBUI_TOKEN=change-this-to-a-long-random-token

# Optional: enable Brave web search tool
NANOBOT_TOOLS__WEB__SEARCH__API_KEY=brv-xxxx

# Optional: if you use another provider, set its API key instead
# NANOBOT_PROVIDERS__OPENAI__API_KEY=sk-xxxx
# NANOBOT_PROVIDERS__ANTHROPIC__API_KEY=sk-ant-xxxx
